Build-Depends: lua/host luci-base/host LUCI_CSSTIDY:csstidy/host LUCI_SRCDIET:luasrcdiet/host 

Package: luci-app-ssr-plus
Submenu: 3. Applications
Version: 196-r6
Depends: +libc +libuci-lua +lua +luci-compat +coreutils +coreutils-base64 +dns2tcp +dnsmasq-full +jq +ip-full +lua-neturl +libuci-lua +microsocks +ipt2socks +lyaml +resolveip +curl +nping +unzip +xz-utils +xz +PACKAGE_luci-app-ssr-plus_INCLUDE_ChinaDNS_NG:chinadns-ng +PACKAGE_luci-app-ssr-plus_INCLUDE_MosDNS:mosdns +PACKAGE_luci-app-ssr-plus_INCLUDE_Shadow_TLS:shadow-tls +PACKAGE_luci-app-ssr-plus_INCLUDE_Kcptun:kcptun-client +PACKAGE_luci-app-ssr-plus_INCLUDE_NaiveProxy:naiveproxy +PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_Rust_Client:shadowsocks-rust-sslocal +PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_Rust_Server:shadowsocks-rust-ssserver +PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_Simple_Obfs:simple-obfs-client +PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_V2ray_Plugin:v2ray-plugin +PACKAGE_luci-app-ssr-plus_INCLUDE_ShadowsocksR_Libev_Client:shadowsocksr-libev-ssr-local +PACKAGE_luci-app-ssr-plus_INCLUDE_ShadowsocksR_Libev_Client:shadowsocksr-libev-ssr-redir +PACKAGE_luci-app-ssr-plus_INCLUDE_ShadowsocksR_Libev_Server:shadowsocksr-libev-ssr-server +luci-lua-runtime
Conflicts: 
Menu-Depends: 
Provides: 
Section: luci
Category: LuCI
Repository: base
Title: SS/SSR/V2Ray/Trojan/NaiveProxy/Tuic/ShadowTLS/Hysteria/Socks5/Clash LuCI interface
Maintainer: OpenWrt LuCI community
Source: 
URL: https://github.com/openwrt/luci
Type: ipkg
Description: SS/SSR/V2Ray/Trojan/NaiveProxy/Tuic/ShadowTLS/Hysteria/Socks5/Clash LuCI interface
@@
Config:

choice
	prompt "Transparent Proxy Backend"
	default PACKAGE_luci-app-ssr-plus_Iptables_Transparent_Proxy if ! PACKAGE_firewall4
	default PACKAGE_luci-app-ssr-plus_Nftables_Transparent_Proxy if PACKAGE_firewall4

config PACKAGE_luci-app-ssr-plus_Iptables_Transparent_Proxy
	bool "Iptables Transparent Proxy"
	depends on !PACKAGE_firewall4
	select PACKAGE_dnsmasq_full_ipset
	select PACKAGE_ipset
	select PACKAGE_iptables
	select PACKAGE_iptables-zz-legacy
	select PACKAGE_iptables-mod-conntrack-extra
	select PACKAGE_iptables-mod-iprange
	select PACKAGE_iptables-mod-socket
	select PACKAGE_iptables-mod-tproxy
	select PACKAGE_kmod-ipt-nat

config PACKAGE_luci-app-ssr-plus_Nftables_Transparent_Proxy
	bool "Nftables Transparent Proxy"
	depends on PACKAGE_firewall4
	select PACKAGE_dnsmasq_full_nftset
	select PACKAGE_nftables
	select PACKAGE_kmod-nft-socket
	select PACKAGE_kmod-nft-tproxy
	select PACKAGE_kmod-nft-nat
endchoice

choice
	prompt "Shadowsocks Client Selection"
	default PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_NONE_Client

	config PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_NONE_Client
	bool "None"

	config PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_Rust_Client
	bool "Shadowsocks Rust"
endchoice

choice
	prompt "Shadowsocks Server Selection"
	default PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_NONE_Server

	config PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_NONE_Server
	bool "None"

	config PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_Rust_Server
	bool "Shadowsocks Rust"
endchoice

choice
	prompt "V2ray-core Selection"
	default PACKAGE_luci-app-ssr-plus_INCLUDE_NONE_V2RAY

	config PACKAGE_luci-app-ssr-plus_INCLUDE_NONE_V2RAY
	bool "None"

	config PACKAGE_luci-app-ssr-plus_INCLUDE_Xray
	bool "Xray-core"
	select PACKAGE_xray-core
	select PACKAGE_coreutils-timeout
endchoice

config PACKAGE_luci-app-ssr-plus_INCLUDE_ChinaDNS_NG
	bool "Include ChinaDNS-NG"
	default y if aarch64||arm||i386||x86_64

config PACKAGE_luci-app-ssr-plus_INCLUDE_MosDNS
	bool "Include MosDNS"
	default n

config PACKAGE_luci-app-ssr-plus_INCLUDE_Http_Proxy
	bool "Include HTTP(S) Proxy Server"
	select PACKAGE_3proxy
	default y if (aarch64||arm||i386||loongarch64||riscv64||x86_64)

config PACKAGE_luci-app-ssr-plus_INCLUDE_Mihomo
	bool "Include Mihomo (Clash Support)"
	select PACKAGE_mihomo
	select PACKAGE_v2ray-geoip
	depends on aarch64||arm||i386||loongarch64||riscv64||x86_64
	default y if aarch64||arm||i386||loongarch64||riscv64||x86_64

config PACKAGE_luci-app-ssr-plus_INCLUDE_GeoData
	bool "Include GeoData (GeoIP and GeoSite)"
	select PACKAGE_v2ray-geoip
	select PACKAGE_v2ray-geosite
	default y if i386||x86_64

config PACKAGE_luci-app-ssr-plus_INCLUDE_Shadow_TLS
	bool "Include Shadow-TLS"
	select PACKAGE_luci-app-ssr-plus_INCLUDE_ChinaDNS_NG
	select PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_Rust_Client
	depends on aarch64||arm||x86_64
	depends on !(TARGET_x86_geode||TARGET_x86_legacy)
	default n

config PACKAGE_luci-app-ssr-plus_INCLUDE_Kcptun
	bool "Include Kcptun"
	default n

config PACKAGE_luci-app-ssr-plus_INCLUDE_NaiveProxy
	bool "Include NaiveProxy"
	depends on !(arc||armeb||mips||mips64||powerpc||TARGET_gemini)
	default n

config PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_Simple_Obfs
	bool "Include Shadowsocks Simple Obfs Plugin"
	default n

config PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_V2ray_Plugin
	bool "Include Shadowsocks V2ray Plugin"
	default n

config PACKAGE_luci-app-ssr-plus_INCLUDE_ShadowsocksR_Libev_Client
	bool "Include ShadowsocksR Libev Client"
	default y

config PACKAGE_luci-app-ssr-plus_INCLUDE_ShadowsocksR_Libev_Server
	bool "Include ShadowsocksR Libev Server"
	default n

@@

